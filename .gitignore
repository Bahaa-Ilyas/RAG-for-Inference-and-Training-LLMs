# Ignore everything by default so this repo can publish one method first.
/*

# Keep repository-level publishing files.
!/.gitignore
!/LICENSE
!/README.md
!/.github/
!/.github/**

# Publish the full inference-RAG collection.
!/inference-RAG/
!/inference-RAG/**

# Never publish generated local artifacts.
**/__pycache__/
**/*.pyc
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.venv/
**/venv/
**/data/local_index.json
**/.env
**/.DS_Store
**/Thumbs.db
